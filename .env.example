# ─── Admin ────────────────────────────────────────────────
# Password for the /admin gallery. Defaults to "gizobekoevlendi" if unset.
ADMIN_PASSWORD=gizobekoevlendi

# ─── Local disk storage (REQUIRED target) ─────────────────
# Absolute path where uploaded media + metadata sidecars are written.
# Must be writable and on persistent storage (a real VPS disk, not /tmp).
# Defaults to <project>/uploads if unset.
UPLOAD_DIR=/var/wedding-uploads

# ─── Cloudflare R2 (best-effort mirror target) ────────────
# If these are unset, uploads still succeed (disk only) and metadata records
# r2: false so they can be re-synced later.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=wedding-uploads
# Optional: override the endpoint. Defaults to
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
