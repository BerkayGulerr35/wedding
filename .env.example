# ─── Admin ────────────────────────────────────────────────
# /admin galerisinin şifresi. Giriş sunucuda buna karşı doğrulanır.
ADMIN_PASSWORD=gizobekoevlendi

# ─── Yerel disk (R2 başarısız olursa fallback hedefi) ─────
# Yükleme önce R2'ye denenir; R2 başarısız olursa medya buraya yazılır.
# Metadata .json sidecar'ı HER ZAMAN buraya yazılır (admin galerisi için).
# SUNUCUDA kalıcı bir yola çevir, örn: /var/wedding-uploads
UPLOAD_DIR=/var/wedding-uploads

# ─── Cloudflare R2 (öncelikli hedef) ──────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=wedding
# İsteğe bağlı; boşsa https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com kullanılır
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# ─── rclone toplu indirme (admin "R2 → sunucu" butonu) ────
# Admin panelindeki buton sunucuda `rclone copy` çalıştırıp tüm R2 arşivini
# buraya indirir. VARSAYILAN: <proje>/r2-archive
# rclone sunucuda KURULU olmalı: curl https://rclone.org/install.sh | sudo bash
# RCLONE_DEST=/var/wedding-archive
